# Library Management System - Environment Configuration
# Copy this file to .env and adjust values as needed

# ── Default Admin Credentials ──────────────────────────────────
DEFAULT_ADMIN_ID=ADMIN001
DEFAULT_ADMIN_PASSWORD=admin123

# ── Loan & Fine Settings ──────────────────────────────────────
ISSUE_DAYS=14
FINE_PER_DAY=5.0
MAX_BORROW_LIMIT=3
MEMBERSHIP_VALIDITY_DAYS=365

# ── Flask Web Server ──────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-in-production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True

# Set to False in production
# FLASK_DEBUG=False

# ── SMTP Email Settings ───────────────────────────────────────
# Configure to enable email notifications for overdue books, reservations, and fines
# Leave blank to disable email sending (notifications will only appear in-app)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@libraryms.com
SMTP_USE_TLS=True
LIBRARY_NAME=Library Management System
EMAIL_NOTIFICATIONS_ENABLED=True
